OPENNEBULA_RPC_URL=http://192.168.122.100:2633/RPC2
PORT=8787
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-this-long-random-value

# Optional: use the Mint OpenNebula VM as an SSH jump host for nested guest VMs.
# This is useful when OpenNebula VMs are on Mint's internal 192.168.122.0/24 network.
SSH_JUMP_HOST=
SSH_JUMP_PORT=22
SSH_JUMP_USER=
SSH_JUMP_PASSWORD=
SSH_JUMP_PRIVATE_KEY=
SSH_JUMP_MATCH_PREFIX=192.168.122.
